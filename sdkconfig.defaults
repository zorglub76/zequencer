# zequencer/sdkconfig.defaults

# ── FreeRTOS ──────────────────────────────────────────────────────────────────
# 1 kHz tick for 1 ms resolution in timing-sensitive tasks
CONFIG_FREERTOS_HZ=1000
# Larger stack for the sequencer/BLE tasks
CONFIG_FREERTOS_IDLE_TASK_STACKSIZE=4096

# ── Bluetooth (NimBLE — lighter than Bluedroid, BLE-only) ────────────────────
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_MODE_BLE_ONLY=y
# Device name shown during BLE advertisement
CONFIG_BT_NIMBLE_SVC_GAP_DEVICE_NAME="Zequencer"
# Max simultaneous BLE connections (1 for a dedicated controller app)
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1
CONFIG_ZEQ_BLE_POSITION_INTERVAL_MS=50

# ── Logging ───────────────────────────────────────────────────────────────────
# Keep INFO level for development; set to WARN for release builds
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_DEBUG=y

# ── UART / MIDI ───────────────────────────────────────────────────────────────
# Reserve UART1 for MIDI — UART0 stays for console/debug
CONFIG_ESP_CONSOLE_UART_NUM=0

# ── Flash / Partition table ───────────────────────────────────────────────────
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# ── Power / CPU ───────────────────────────────────────────────────────────────
# 240 MHz for tight ISR timing
CONFIG_ESP32C3_DEFAULT_CPU_FREQ_160=y

# ── Watchdog ──────────────────────────────────────────────────────────────────
# Disable task watchdog interference during development
CONFIG_ESP_TASK_WDT_PANIC=n
CONFIG_ESP_INT_WDT=n
CONFIG_ESP_TASK_WDT_EN=n

# ── Zequencer MIDI defaults
CONFIG_ZEQ_MIDI_UART_PORT=1
CONFIG_ZEQ_MIDI_TX_GPIO=5

CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"